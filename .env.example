# Base URL for canonical links, OG tags, and sitemap
VITE_SITE_URL=https://www.instructra.com

# Set to true on preview/staging to prevent search-engine indexing
VITE_NO_INDEX=true
# Omit or set to false in production

# Resend — email sending (server-side only, never expose to the browser)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY='re_8Gi9CUPG_FawNC6wqnVgnvqoPAyAcH2s7

# The address to send form submissions to (defaults to info@instructra.com)
CONTACT_TO_EMAIL=info@instructra.com

# The "from" address — must be a verified Resend domain/email
# During development you can use: onboarding@resend.dev (sends only to your account email)
RESEND_FROM_EMAIL=Instructra <noreply@instructra.com>
